@using Investissement_WebClient.Application.ChartsOptions
@using Investissement_WebClient.Application.ViewsModels.Graphiques
@using Investissement_WebClient.Application.ViewsModels.Graphiques.Patrimoines

@*Graphique Candle + Line : evolution de la valeur du patrimoine (Candle) par rapport à l'invetsissement total (Line) au cours du temps*@

@if (BougiesJournalieresValeurPatrimoineSurInvestissementTotal.Any())
{
    <div style="flex:1">
        <ApexChart TItem="BougieJournaliereCandleChartVM"
                   XAxisType="XAxisType.Datetime"
                   Options="PatrimoineChartsOptions.OptionsBougieJournaliereValeurPatrimoineSurInvestissementTotal">

            <ApexCandleSeries TItem="BougieJournaliereCandleChartVM"
                              Items="BougiesJournalieresValeurPatrimoineSurInvestissementTotal"
                              Name="Evolution de la valeur du patrimoine"
                              XValue="@(e => e.Date)"
                              Open="@(e => e.Ouverture)"
                              High="@(e => e.Haut)"
                              Low="@(e => e.Bas)"
                              Close="@(e => e.Fermeture)"
                              OrderByDescending="e => e.X" />

            <ApexPointSeries TItem="BougieJournaliereCandleChartVM"
                             Items="BougiesJournalieresValeurPatrimoineSurInvestissementTotal"
                             SeriesType="SeriesType.Line"
                             Name="Investissement total"
                             YValue="@(e => e.InvestissementTotal)"
                             XValue="@(e => e.Date)"
                             Stroke="@(new SeriesStroke{ Width=3, DashSpace=3, Color="yellow" })" />
        </ApexChart>
    </div>      
}

@code {
    [Parameter] public IEnumerable<BougieJournaliereCandleChartVM> BougiesJournalieresValeurPatrimoineSurInvestissementTotal { get; set; } = [];
}
