@using Investissement_WebClient.Application.ChartsOptions
@using Investissement_WebClient.Application.ViewsModels.Graphiques.Profils

<ApexChart @ref="_chart"
           TItem="ValeurParAnLineChartVM"
           Options="ProfilChartsOptions.OptionsValeurParAn">

    <ApexPointSeries TItem="ValeurParAnLineChartVM"
                     Items="PerspectivesValeurPatrimoineParAn"
                     SeriesType="SeriesType.Line"
                     Name="Valeur Patrimoine"
                     YValue="@(e => e.Valeur)"
                     XValue="@(e => e.Annee)"
                     Stroke="@(new SeriesStroke{ Width=3, DashSpace=2, Color="goldenrod" })" />

    <ApexPointSeries TItem="ValeurParAnLineChartVM"
                     Items="PerspectivesValeurPatrimoineParAn"
                     SeriesType="SeriesType.Line"
                     Name="Investissement"
                     YValue="@(e => e.Investissement)"
                     XValue="@(e => e.Annee)"
                     Stroke="@(new SeriesStroke{ Width=3, Color="grey" })" />
</ApexChart>

@code {
    [Parameter] public List<ValeurParAnLineChartVM> PerspectivesValeurPatrimoineParAn { get; set; } = [];
    private ApexChart<ValeurParAnLineChartVM>? _chart { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (_chart != null)
        {
            await _chart.UpdateSeriesAsync();
        }
    }
}
