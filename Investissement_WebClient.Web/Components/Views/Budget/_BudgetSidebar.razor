@using Investissement_WebClient.Domain
@using Investissement_WebClient.Domain.Configurations
@using Investissement_WebClient.Domain.Enums
@using Investissement_WebClient.Web.Components.ViewsModels

@inject NavigationManager Nav

<div class="header">
    <label>Historique</label>

    @if (Model.ConnexionBanqueRequise)
    {
        <button type="button" class="btn-sync-banque"
                @onclick="RedirigerVersPowens"
                title="Votre accès bancaire doit être renouvelé pour récupérer les derniers flux (sécurité tous les 90 jours).">
            🔄 Synchroniser ma banque 🔄
        </button>
    }
</div>

<div class="content">

    <div class="un-mois recap @(Model.DateActive == null ? "active-recapitulatif-global " : "")"
                        @onclick="Model.SetRecapGlobalMode">
        <span>📊 Récapitulatif global 📊</span>
    </div>

    @foreach (var unMois in Model.StatutsParMois)
    {
        var estIndisponible = false;
        var icon = string.Empty;
        var statut = string.Empty;
        @switch (unMois.Statut)
        {
            case Statut.indisponible:
                estIndisponible = true;
                icon = "⛔";
                statut = "indisponible";
                break;
            case Statut.en_cours:
                icon = "🕒";
                statut = "en cours";
                break;
            case Statut.complete:
                icon = "✅";
                statut = "completé";
                break;
            case Statut.aucune_donnees:
                icon = "🔍";
                statut = "aucune données";
                break;
        }

        var estActif = Model.DateActive.HasValue
                    && Model.DateActive.Value.Year == unMois.Date.Year
                    && Model.DateActive.Value.Month == unMois.Date.Month;

        <div class="un-mois @(estIndisponible || Model.ConnexionBanqueRequise ? "disabled" : estActif ? "active" : "")"
             @onclick="async () => { if (!estIndisponible && !Model.ConnexionBanqueRequise) { await Model.LoadFluxUnMois(unMois); } }">
            <span>@(icon + " " + unMois.Date.ToString("MMMM yyyy") + " - " + statut)</span>
        </div>
    }
</div>


@code{
    [Parameter] public required BudgetViewModel Model { get; set; }

    public void RedirigerVersPowens()
    {
        Nav.NavigateTo(PowensConfiguration.GetConnexionUrl(), forceLoad: true);
    }
}