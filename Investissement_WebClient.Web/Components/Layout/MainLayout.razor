@inherits LayoutComponentBase
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<BlazoredToasts Position="ToastPosition.TopRight"
                Timeout="10"
                IconType="IconType.FontAwesome"/>

<div class="main-layout">
    <nav>
        <NavLink class="nav-link" href="/budget">
            <div class="link">Budget</div>
        </NavLink>

        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
            <div class="link">Investissement</div>
        </NavLink>
    
        <NavLink class="nav-link" href="/patrimoine">
            <div class="link">Patrimoine</div>
        </NavLink>

        <NavLink class="nav-link" href="/profil">
            <div class="link">Profil</div>
        </NavLink>
    </nav>

    @Body

    <footer>
        <div class="footer-content">
            <label>© Investissement 2025 - @(DateTime.Today.Year) </label>
        </div>
    </footer>
</div>