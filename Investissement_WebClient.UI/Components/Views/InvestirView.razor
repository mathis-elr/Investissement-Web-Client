@using System.Globalization
@using System.Transactions
@using Investissement_WebClient.Core.Modeles.DTO
@using Investissement_WebClient.UI.Components.ViewsModels;
@page "/"
@rendermode InteractiveServer
@inject InvestirViewModel IVM
@inject IJSRuntime JS
@inject IToastService TS


<PageTitle>Investir</PageTitle>

<div class="investir">
    <div class="investissement">
        <div class="investissement-header">
            <div class="online">
                <label>Investissement du</label>
                <input @bind="IVM.SelectedDateInvest" type="date"/>
            </div>
            <div class="online">
                <label>Ajouter le modèle</label>
                <select @onchange="IVM.OnChangeModele">
                    <option>Aucun</option>
                    @foreach (ModeleDto modele in IVM.Modeles)
                    {
                        <option value="@modele.Id">@modele.Nom</option>
                    }
                </select>
                @if(IVM.SelectedIdModele == null)
                {
                    <label>Note</label>
                    <input type="text" @bind="IVM.NoteInvestissement"/>
                }
            </div>
        </div>

        <div class="investissement-content">
            @foreach (var transaction in IVM.TransactionsInvestissement)
            {
                <div class="transaction-investissement">
                    <div class="actif-transaction">
                        <select Tvalue="int" @bind="transaction.IdActif">
                            <option value="0" disable>-- Sélectionnez un actif --</option>
                            @foreach (ActifDto actif in IVM.ActifsEnregistre)
                            {
                                <option value="@actif.Id">@actif.Nom</option>
                            }
                        </select>
                        <div type="button" class="dell" @onclick="() => IVM.DellTransactionInvest(transaction)">✕</div>
                    </div>
                    <div class="valeurs-transaction">
                        <input type="number" @bind="transaction.Quantite" placeholder="Quantité investit"/>
                        <input type="number" @bind="transaction.Prix" placeholder="Prix d'achat (€)"/>
                        <input type="number" @bind="transaction.Frais" placeholder="Frais (€)"/>
                    </div>
                </div>
            }
            @if (IVM.ActifsEnregistre.Count() != 0)
            {
                <div class="actif-investissement add" @onclick="IVM.AddTransactionInvest">
                    <a>+</a>
                </div>
            }
        </div>

        @if (IVM.TransactionsInvestissement.Count != 0)
        {
            <div class="investissement-footer">
                <button @onclick="Investir" class="btn-investir">Investir</button>
            </div>
        }
    </div>

    <div class="mes-investissements">
        <div class="mes-investissements-header">
            <label>Mes Investissements</label>
        </div>
        <div class="mes-investissements-content">
            @foreach (var investissementsParDate in IVM.Investissements.GroupBy(i => i.DateInvest.Date))
            {
                <div class="mes-investissements-journalier">
                    <div class="date-total-mes-investissement-journalier">
                        <label>@investissementsParDate.Key.ToString("D", CultureInfo.CreateSpecificCulture("fr-FR")) &nbsp</label>
                        <span></span>
                        <label>@(investissementsParDate.Sum(t => t.Transactions.Sum(tr => tr.Prix * tr.Quantite))?.ToString("C2", System.Globalization.CultureInfo.CreateSpecificCulture("fr-FR")))</label>
                    </div>
                    <div class="un-investissement-journalier">
                        @foreach(var investissementJour in investissementsParDate)
                        {
                            <div class="mes-transactions-investissement-journalier">
                                <div class="modele-et-annuler">
                                    @if (investissementJour.Modele != null)
                                    {
                                        <label>@investissementJour.Modele.Nom</label>
                                    }
                                    else if(investissementJour.Note != null)
                                    {
                                        <label>@investissementJour.Note</label>
                                    }
                                    @if (investissementJour.DateInvest.AddHours(3) > DateTime.Now 
                                         && investissementsParDate.Max(i => i.DateInvest) == investissementJour.DateInvest)
                                    {
                                        <div class="btn-annuler-dernier-invest" @onclick="() => DeleteDernierInvest(investissementJour)">Annuler</div>
                                    }
                                </div>
                                @foreach (TransactionDto transaction in investissementJour.Transactions)
                                {
                                    <div class="une-transaction-investissement-journalier">
                                        <span></span>
                                        <span>@transaction.Quantite @transaction.NomActif à @transaction.Prix?.ToString("C", CultureInfo.CreateSpecificCulture("fr-FR"))</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code{
    protected override async Task OnInitializedAsync()
    {
        await IVM.LoadData();
    }

    async Task DeleteDernierInvest(InvestissementGetDto investissementGetDto)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Voulez-vous vraiment supprimer le dernier investissement ?"))
        {
            await IVM.DeleteDernierInvest(investissementGetDto);
        }
    }

    async Task Investir()
    {
        await IVM.Investir();

        if(IVM.HasError)
        {
            TS.ShowError(IVM.ErrorMessage);
            IVM.HasError = false;
            IVM.ErrorMessage = string.Empty;
        }
        else
        {
            TS.ShowSuccess("Investissement effectué avec succès !");
        }
    }
}