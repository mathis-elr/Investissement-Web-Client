@using Investissement_WebClient.Core.Modeles.DTO
@using Investissement_WebClient.UI.Components.ViewsModels;

@page "/actif"
@rendermode InteractiveServer
@inject IToastService TS
@inject IJSRuntime JS
@inject ActifViewModel AVM

<PageTitle>Actif</PageTitle>

<div class="actif">
    
    <Formulaire AVM="AVM" Soumission="Soumission"></Formulaire>

    <div class="mes-actifs">
        <div class="mes-actifs-header">
            <label>Actifs enregistrés</label>

            <div class="btns">
                <button disabled="@(!AVM.ActifASuppr.Any())" class="btn-effacer-selection" @onclick="AVM.EffacerSelectionSuppresion">Annuler</button>
                <button disabled="@(!AVM.ActifASuppr.Any())" class="btn-suppr" @onclick="Supprimer">Supprimer</button>
            </div>
        </div>

        <div class="mes-actifs-content">
            @foreach (var typeActif in AVM.ActifsEnregistre.GroupBy(a => a.Type))
            {
                <div class="un-type-actif">
                    <label>@typeActif.Key</label>
                    <div class="un-type-actif-content">
                        @foreach (ActifDto actif in typeActif)
                        {
                            <div class="un-actif-enregistre" @onclick="() => AVM.ChangerEtatSuppression(actif.Id)">
                                <span></span>
                                <label class="@(AVM.ActifASuppr.Contains(actif.Id) ? "active" : "")">@actif.Nom</label>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code{
    protected override async Task OnInitializedAsync()
    {
        await AVM.LoadData();
    }
    
    private async Task Soumission()
    {
        if (AVM.SelectedMode == "Ajouter")
        {
            await Ajouter();
        }
        else
        {
            await Editer();
        }
    }
    
    private async Task Ajouter()
    {
        await AVM.Ajouter();

        if (AVM.HasError)
        {
            TS.ShowError(AVM.ErrorMessage);
        }
        else
        {
            TS.ShowSuccess("Actif enregistré avec succès !");
        }
    }
    
    private async Task Editer()
    {
        await AVM.Editer();

        if (AVM.HasError)
        {
            TS.ShowError(AVM.ErrorMessage);
        }
        else
        {
            TS.ShowSuccess("Actif modifié avec succès !");
        }
    }

    private async Task Supprimer()
    {
        if (await JS.InvokeAsync<bool>("confirm", "Voulez-vous vraiment supprimer" + (AVM.ActifASuppr.Count() > 1 ? "ces actifs" : "cet actif")))
        {
            await AVM.Supprimer();

            if (AVM.HasError)
            {
                TS.ShowError(AVM.ErrorMessage);
            }
            else
            {
                TS.ShowSuccess("Actif(s) supprimé(s) avec succès !");
            }
        }
    }
}